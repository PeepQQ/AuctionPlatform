generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @default("Unknown")
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  refreshToken String?

  lots         Lot[]
  bets         LotBet[]
}

model Lot {
  id          Int          @id @default(autoincrement())
  name        String
  description String
  price       Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  startAt     DateTime
  ownerId     Int

  owner       User         @relation(fields: [ownerId], references: [id])
  pictures    LotPicture[]
  bets        LotBet[]
}

model LotPicture {
  id    Int    @id @default(autoincrement())
  lotId Int
  path  String
  lot   Lot    @relation(fields: [lotId], references: [id])
}

model LotBet {
  id       Int    @id @default(autoincrement())
  summ     Int
  date     DateTime     @default(now())
  lotId    Int
  userId   Int
  username String

  lot      Lot    @relation(fields: [lotId], references: [id])
  user     User   @relation(fields: [userId], references: [id])
}